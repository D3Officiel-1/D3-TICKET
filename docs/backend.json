
{
  "entities": {
    "Ticket": {
      "title": "Ticket",
      "description": "Un ticket de tombola ou d'événement généré.",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Le code unique du ticket."
        },
        "type": {
          "type": "string",
          "description": "Le type de ticket (ex: standard, vip, st_exupery).",
          "enum": ["standard", "vip", "st_exupery"]
        },
        "status": {
          "type": "string",
          "description": "Statut du ticket (valid, used, etc.)."
        },
        "imprimer": {
          "type": "boolean",
          "description": "Désigne si le ticket a déjà été imprimé."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date de création."
        },
        "validatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date de validation (scan)."
        }
      },
      "required": ["code", "type"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Collection des tickets disponibles."
    }
  }
}
